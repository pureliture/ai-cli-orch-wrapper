{
  "name": "@pureliture/ai-cli-orch-wrapper",
  "version": "0.4.0",
  "description": "Installable aco CLI package for command pack setup, provider setup, execution, and session lifecycle.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aco": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "mkdir -p templates && cp -r ../../templates/* templates/",
    "test": "node --require tsx/cjs --test tests/providers.test.ts tests/session.test.ts tests/sentinel.test.ts",
    "test:smoke": "tsx tests/smoke.ts",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
