{
  "name": "aco-install",
  "version": "0.4.0",
  "description": "Installer CLI for the aco Claude Code command pack.",
  "main": "dist/cli.js",
  "bin": {
    "aco-install": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aco/wrapper": "^0.4.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
