.codex/worktrees/
.gemini/worktrees/
.aco-worktrees/

# Claude Octopus runtime state
.omc/
.omx/

# Harness configuration (Whitelist approach)
.codex/*
!.codex/agents/
!.codex/skills/
!.codex/hooks.json

.gemini/*
!.gemini/agents/
!.gemini/commands/
!.gemini/skills/
