# Local settings (strictly ignored)
.claude/settings.local.json

# Claude Code session files (non-persistent)
.claude/session-intent.md
.claude/session-plan.md
.claude/skills/
!.claude/skills/
!.claude/skills/**

# Claude Octopus runtime state
.claude-octopus/

# GitHub Copilot prompts/skills
.github/prompts/
.github/skills/


# Go build artifacts
/bin/

# agy per-project config directory (symlink created by agy when run from cwd)
# Known agy behavior: agy creates .antigravitycli/ symlink in cwd pointing to ~/.gemini/config/projects/<id>.json
.antigravitycli/

# Dev-process / repo-specific harness — kept locally, not distributed or pushed
# improve-codebase-architecture: this-repo-only architecture review skill
.claude/skills/improve-codebase-architecture/
.agents/skills/improve-codebase-architecture/
templates/skills/improve-codebase-architecture/
# OpenSpec dev tooling (spec-driven workflow used to develop this repo)
.claude/skills/openspec-*/
.claude/commands/opsx/
.codex/skills/openspec-*/

# Local scratch / runtime cruft (not part of the repo)
/commit.msg
/cache/
