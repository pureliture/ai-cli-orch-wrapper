{
  "name": "ai-cli-orch-wrapper",
  "version": "0.4.0",
  "description": "Claude Code slash-command pack for Gemini CLI and GitHub Copilot CLI — installable npm workspace.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspace=packages/wrapper",
    "test:smoke": "npm run test:smoke --workspace=packages/wrapper --if-present"
  },
  "keywords": [
    "claude-code",
    "gemini-cli",
    "copilot-cli",
    "slash-commands"
  ],
  "license": "MIT"
}
