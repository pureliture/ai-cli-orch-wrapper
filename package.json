{
  "name": "ai-cli-orch-wrapper",
  "version": "0.2.0",
  "description": "Lightweight URL downloader with lock-file tracking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aco": "dist/cli.js"
  },
  "scripts": {
