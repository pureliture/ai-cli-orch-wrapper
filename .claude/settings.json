{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/pm-hook.sh",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  }
}
